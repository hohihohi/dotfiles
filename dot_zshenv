### PATH ###
# default path
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
# add binaries on home directory
export PATH="$HOME/bin:$PATH"
# add brew application's binary path
export PATH="/opt/homebrew/bin:$PATH"
# add brew sudo binary path
export PATH="/opt/homebrew/sbin:$PATH"

### XDG Base Directory Spec ###
# ref: https://specifications.freedesktop.org/basedir-spec/latest/
# XDG config file
export XDG_CONFIG_HOME="$HOME/.config"
# XDG cache file
export XDG_CACHE_HOME="$HOME/.cache"
# XDG data file
export XDG_DATA_HOME="$HOME/.local/share"
# XDG state file
export XDG_STATE_HOME="$HOME/.local/state"

### EDITOR ###
# default editor
export EDITOR="vim"
# rich editor
export VISUAL="nvim"

### HISTORY ###
# history file path
export HISTFILE=~/.zsh_history
# history size on memory
export HISTSIZE=10000
# history size on file
export SAVEHIST=100000

### PROPMT ###
export STARSHIP_CONFIG="$XDG_CONFIG_HOME/starship/config.toml"
export STARSHIP_CACHE="$XDG_CACHE_HOME/starship"
# WRAN: PROMPT env val is overwritten starship plug-in.
# If I'd like to apply line-break into prompt, I should specify it after plug-in applied
# export PROMPT="${PROMPT}"$'\n'

### OTHER ###
# colorizing pager for man command
# https://github.com/sharkdp/bat/issues/1433#issuecomment-3708644390
export MANPAGER="sh -c 'col -bx | bat -l man -p'" man ls
# Options for path completion (e.g. vim **<TAB>): show dir and file which contains dot file and dir
export FZF_COMPLETION_PATH_OPTS='--walker file,dir,follow,hidden'
# Options for directory completion (e.g. cd **<TAB>): show only dir which contains dot dir
export FZF_COMPLETION_DIR_OPTS='--walker dir,follow,hidden'
# zellij config path
export ZELLIJ_CONFIG_DIR="$XDG_CONFIG_HOME/zellij"
