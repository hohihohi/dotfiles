include ~/.ssh/conf.d/**/config

# default settings
Host *
    StrictHostKeyChecking no
    UserKnownHostsFile=/dev/null
    ServerAliveInterval 15
    ServerAliveCountMax 30
    IdentitiesOnly yes
    TCPKeepAlive yes
