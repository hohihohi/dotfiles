### Language management ###
# If mise exists
if type mise > /dev/null 2>&1; then
    # Run to ensure you use the correct versions
    eval "$(/opt/homebrew/bin/mise activate zsh)"
    local miselist="$(mise ls --json | jq -r 'keys[]')"
    # Install NodeJS
    # -q: quiet, -x: --line-regexp, -F: fixed-strings
    echo "$miselist" | grep -qxF node || mise install node@latest
    # Install Python
    echo "$miselist" | grep -qxF node || mise install python@latest
    # Install go
    echo "$miselist" | grep -qxF node || mise install go@latest
    # Install terraform
    echo "$miselist" | grep -qxF node || mise install terraform@latest
else
    echo "NOT found mise command. please install mise"
fi

### History ###
# Treat the '!' character specially during expansion.
setopt BANG_HIST
# Write the history file in the ':start:elapsed;command' format.
setopt EXTENDED_HISTORY
# Share history between all sessions.
setopt SHARE_HISTORY
# Expire a duplicate event first when trimming history.
setopt HIST_EXPIRE_DUPS_FIRST
# Do not record an event that was just recorded again.
setopt HIST_IGNORE_DUPS
# Delete an old recorded event if a new event is a duplicate.
setopt HIST_IGNORE_ALL_DUPS
# Do not display a previously found event.
setopt HIST_FIND_NO_DUPS
# Do not record an event starting with a space.
setopt HIST_IGNORE_SPACE
# Do not write a duplicate event to the history file.
setopt HIST_SAVE_NO_DUPS
# Do not execute immediately upon history expansion.
setopt HIST_VERIFY
